# ============================================================
# FRONTEND ENVIRONMENT CONFIG — Copy this file to .env
# and fill in your own values before running.
# ============================================================

# URL where your local Strapi backend is running
# For production, set this to your deployed backend URL (e.g., Railway, Heroku)
VITE_STRAPI_URL=http://localhost:1337

# Supabase (for Contact form submissions)
# Use ANON key only (never service_role on frontend)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_CONTACT_TABLE=contact_submissions
