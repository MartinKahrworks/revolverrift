# ============================================================
# BACKEND ENVIRONMENT CONFIG
# Copy this file to .env and fill in the real values.
# Get the actual secret values from Yash directly (private channel).
# ============================================================

# ----------------------------
# Server
# ----------------------------
HOST=0.0.0.0
PORT=1337

# ----------------------------
# Strapi Secrets
# ⚠️  IMPORTANT: Use the EXACT SAME values as your teammate.
# Since we share a Neon database, tokens stored in the DB must
# be verifiable by both machines. Get these values from Yash.
# ----------------------------
APP_KEYS=key1Base64==,key2Base64==,key3Base64==,key4Base64==
API_TOKEN_SALT=replaceWithSharedValue==
ADMIN_JWT_SECRET=replaceWithSharedValue==
TRANSFER_TOKEN_SALT=replaceWithSharedValue==
ENCRYPTION_KEY=replaceWithSharedValue==
JWT_SECRET=replaceWithSharedValue==

# ----------------------------
# Neon PostgreSQL (Shared Cloud Database)
# Get connection string from Yash or from neon.tech dashboard.
# Project: revolverrift
# ----------------------------
DATABASE_CLIENT=postgres
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_SSL=true

# ----------------------------
# Cloudinary (Shared Media Storage)
# Get these from cloudinary.com → Dashboard
# Both developers use the SAME Cloudinary account.
# ----------------------------
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_KEY=your_api_key
CLOUDINARY_SECRET=your_api_secret
