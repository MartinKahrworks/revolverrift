{
    "kind": "collectionType",
    "collectionName": "news_items",
    "info": {
        "singularName": "news-item",
        "pluralName": "news-items",
        "displayName": "news-item"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "badge_label": {
            "type": "string",
            "required": true,
            "default": "Feature Analysis"
        },
        "badge_color": {
            "type": "enumeration",
            "enum": [
                "red",
                "beige"
            ],
            "default": "red"
        },
        "excerpt": {
            "type": "text"
        },
        "content": {
            "type": "blocks"
        },
        "cover_image": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "publish_date": {
            "type": "date"
        },
        "order": {
            "type": "integer",
            "default": 99
        }
    }
}