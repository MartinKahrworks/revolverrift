{
  "kind": "collectionType",
  "collectionName": "contents",
  "info": {
    "singularName": "content",
    "pluralName": "contents",
    "displayName": "content"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "body": {
      "type": "blocks",
      "required": true
    },
    "background_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "align_text": {
      "type": "enumeration",
      "enum": [
        "left",
        "right",
        "center"
      ],
      "default": "right",
      "required": true
    },
    "bg_position": {
      "type": "string",
      "default": "center center"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}