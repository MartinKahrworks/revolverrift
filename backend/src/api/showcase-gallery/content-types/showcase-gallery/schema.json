{
  "kind": "collectionType",
  "collectionName": "showcase_galleries",
  "info": {
    "singularName": "showcase-gallery",
    "pluralName": "showcase-galleries",
    "displayName": "showcase-gallery"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "screenshot",
        "artwork",
        "weapon",
        "environment"
      ],
      "default": "screenshot"
    },
    "orientation": {
      "type": "enumeration",
      "enum": [
        "landscape",
        "portrait",
        "square",
        "panoramic"
      ],
      "default": "landscape"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "order": {
      "type": "integer",
      "default": 99
    }
  }
}