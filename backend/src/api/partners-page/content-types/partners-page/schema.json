{
  "kind": "singleType",
  "collectionName": "partners_pages",
  "info": {
    "singularName": "partners-page",
    "pluralName": "partners-pages",
    "displayName": "partners-page"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "heroTitle": {
      "type": "string",
      "default": "Elite Access Recruitment"
    },
    "heroSubtitle": {
      "type": "text",
      "default": "Join the inner circle. Revolver Rift's creator program is built for those who don't just play — they lead."
    },
    "primaryButtonText": {
      "type": "string",
      "default": "Apply Now"
    },
    "secondaryButtonText": {
      "type": "string",
      "default": "View Tiers"
    },
    "tiersHeading": {
      "type": "string",
      "default": "Tier Progression"
    },
    "tiers": {
      "type": "component",
      "repeatable": true,
      "component": "sections.partner-stage"
    },
    "applicationHeading": {
      "type": "string",
      "default": "How to Apply"
    },
    "applicationSteps": {
      "type": "component",
      "repeatable": true,
      "component": "sections.application-step"
    },
    "applicationNote": {
      "type": "text",
      "default": "The final decision rests with KAHRWORKS. Review may take 1–2 months."
    },
    "ctaTitle": {
      "type": "string",
      "default": "Ready to Represent Revolver Rift?"
    },
    "ctaButtonText": {
      "type": "string",
      "default": "Apply Now"
    },
    "ctaLink": {
      "type": "string",
      "default": "/contact"
    },
    "featuredPartners": {
      "type": "component",
      "repeatable": true,
      "component": "sections.partner-logo"
    },
    "background_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    }
  }
}